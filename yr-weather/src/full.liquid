<script src="https://trmnl.com/js/highcharts/12.3.0/highcharts.js"></script>
<script src="https://trmnl.com/js/highcharts/12.3.0/pattern-fill.js"></script>

<style>
  .weather-current {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 16px 12px;
    font-family: sans-serif;
  }

  .weather-current-icon {
    width: 96px;
    height: 96px;
    margin-bottom: 4px;
  }

  .weather-current-temp {
    font-size: 60px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -2px;
  }

  .weather-current-feels {
    font-size: 15px;
    opacity: 0.6;
    margin-top: 2px;
    margin-bottom: 16px;
  }

  .weather-current-details {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-size: 15px;
  }

  .weather-current-highlow {
    display: flex;
    gap: 10px;
    font-weight: 600;
  }

  .weather-current-wind {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .weather-current-wind img {
    width: 20px;
    height: 20px;
  }

  .title_bar { background: none !important; justify-content: center; }
</style>

<div class="view view--full">
  <div class="layout layout--row" style="flex:1; min-height:0;">
    <div class="weather-current" style="width:220px; flex-shrink:0; border-right:1px solid #000;">
      <img id="current-icon" class="weather-current-icon" src="" alt="" />
      <div id="current-temp" class="weather-current-temp"></div>
      <div id="current-feels" class="weather-current-feels"></div>
      <div class="weather-current-details">
        <div id="current-highlow" class="weather-current-highlow"></div>
        <div id="current-wind" class="weather-current-wind"></div>
      </div>
    </div>
    <div id="weather-chart" class="w--full" style="flex:1; min-width:0;"></div>
  </div>
  <div class="title_bar">
    <span class="title" id="weather-tip">Ha en fin dag!</span>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  /* ────────────────────────────────────
     A. Data binding
     ──────────────────────────────────── */
  var rawData = {{ data | json }};
  var trmnlCtx = {{ trmnl | json }};
  var timeseries = (rawData && rawData.properties && rawData.properties.timeseries) || [];

  /* ────────────────────────────────────
     B. Timezone helpers (Europe/Oslo)
     ──────────────────────────────────── */
  var osloFmt = new Intl.DateTimeFormat('no-NO', {
    timeZone: 'Europe/Oslo',
    year: 'numeric', month: 'numeric', day: 'numeric',
    hour: 'numeric', minute: 'numeric', hour12: false
  });

  function osloHour(isoString) {
    var parts = osloFmt.formatToParts(new Date(isoString));
    var h = 0;
    parts.forEach(function (p) { if (p.type === 'hour') h = parseInt(p.value, 10); });
    return h;
  }

  function osloDay(isoString) {
    var parts = osloFmt.formatToParts(new Date(isoString));
    var d = 0;
    parts.forEach(function (p) { if (p.type === 'day') d = parseInt(p.value, 10); });
    return d;
  }

  /* "now" in Oslo */
  var tsUtc = (trmnlCtx && trmnlCtx.system && trmnlCtx.system.timestamp_utc)
    ? Number(trmnlCtx.system.timestamp_utc) * 1000
    : Date.now();
  var nowDate = new Date(tsUtc);
  var todayDay = osloDay(nowDate.toISOString());

  /* ────────────────────────────────────
     C. Inline icons (base64) + symbol code mapping
     ──────────────────────────────────── */
  var ICONS = {'wi-day-sunny':'data:image/svg+xml;base64,','wi-day-cloudy-high':'data:image/svg+xml;base64,','wi-day-cloudy':'data:image/svg+xml;base64,','wi-cloudy':'data:image/svg+xml;base64,','wi-day-fog':'data:image/svg+xml;base64,','wi-day-sprinkle':'data:image/svg+xml;base64,','wi-day-showers':'data:image/svg+xml;base64,','wi-day-rain':'data:image/svg+xml;base64,','wi-sprinkle':'data:image/svg+xml;base64,','wi-rain':'data:image/svg+xml;base64,','wi-showers':'data:image/svg+xml;base64,','wi-day-sleet':'data:image/svg+xml;base64,','wi-sleet':'data:image/svg+xml;base64,','wi-day-snow':'data:image/svg+xml;base64,','wi-day-snow-wind':'data:image/svg+xml;base64,','wi-snow':'data:image/svg+xml;base64,','wi-snow-wind':'data:image/svg+xml;base64,','wi-day-storm-showers':'data:image/svg+xml;base64,','wi-thunderstorm':'data:image/svg+xml;base64,','wi-day-thunderstorm':'data:image/svg+xml;base64,','wi-day-sleet-storm':'data:image/svg+xml;base64,','wi-day-snow-thunderstorm':'data:image/svg+xml;base64,','wi-night-clear':'data:image/svg+xml;base64,','wi-night-cloudy-high':'data:image/svg+xml;base64,','wi-night-alt-cloudy':'data:image/svg+xml;base64,','wi-night-fog':'data:image/svg+xml;base64,','wi-night-alt-sprinkle':'data:image/svg+xml;base64,','wi-night-alt-showers':'data:image/svg+xml;base64,','wi-night-alt-rain':'data:image/svg+xml;base64,','wi-night-alt-sleet':'data:image/svg+xml;base64,','wi-night-alt-snow':'data:image/svg+xml;base64,','wi-night-alt-snow-wind':'data:image/svg+xml;base64,','wi-night-alt-storm-showers':'data:image/svg+xml;base64,','wi-night-alt-thunderstorm':'data:image/svg+xml;base64,','wi-night-alt-sleet-storm':'data:image/svg+xml;base64,','wi-night-alt-snow-thunderstorm':'data:image/svg+xml;base64,','wi-strong-wind':'data:image/svg+xml;base64,','wi-na':'data:image/svg+xml;base64,',};

  var ICON_MAP = {
    clearsky:                    { day: 'wi-day-sunny',               night: 'wi-night-clear' },
    fair:                        { day: 'wi-day-cloudy-high',         night: 'wi-night-cloudy-high' },
    partlycloudy:                { day: 'wi-day-cloudy',              night: 'wi-night-alt-cloudy' },
    cloudy:                      { day: 'wi-cloudy',                  night: 'wi-cloudy' },
    fog:                         { day: 'wi-day-fog',                 night: 'wi-night-fog' },
    lightrainshowers:            { day: 'wi-day-sprinkle',            night: 'wi-night-alt-sprinkle' },
    rainshowers:                 { day: 'wi-day-showers',             night: 'wi-night-alt-showers' },
    heavyrainshowers:            { day: 'wi-day-rain',                night: 'wi-night-alt-rain' },
    lightrain:                   { day: 'wi-sprinkle',                night: 'wi-sprinkle' },
    rain:                        { day: 'wi-rain',                    night: 'wi-rain' },
    heavyrain:                   { day: 'wi-showers',                 night: 'wi-showers' },
    lightsleetshowers:           { day: 'wi-day-sleet',               night: 'wi-night-alt-sleet' },
    sleetshowers:                { day: 'wi-day-sleet',               night: 'wi-night-alt-sleet' },
    heavysleetshowers:           { day: 'wi-day-sleet',               night: 'wi-night-alt-sleet' },
    lightsleet:                  { day: 'wi-sleet',                   night: 'wi-sleet' },
    sleet:                       { day: 'wi-sleet',                   night: 'wi-sleet' },
    heavysleet:                  { day: 'wi-sleet',                   night: 'wi-sleet' },
    lightsnowshowers:            { day: 'wi-day-snow',                night: 'wi-night-alt-snow' },
    snowshowers:                 { day: 'wi-day-snow',                night: 'wi-night-alt-snow' },
    heavysnowshowers:            { day: 'wi-day-snow-wind',           night: 'wi-night-alt-snow-wind' },
    lightsnow:                   { day: 'wi-snow',                    night: 'wi-snow' },
    snow:                        { day: 'wi-snow',                    night: 'wi-snow' },
    heavysnow:                   { day: 'wi-snow-wind',               night: 'wi-snow-wind' },
    lightrainandthunder:         { day: 'wi-day-storm-showers',       night: 'wi-night-alt-storm-showers' },
    rainandthunder:              { day: 'wi-thunderstorm',            night: 'wi-thunderstorm' },
    heavyrainandthunder:         { day: 'wi-thunderstorm',            night: 'wi-thunderstorm' },
    lightrainshowersandthunder:  { day: 'wi-day-thunderstorm',        night: 'wi-night-alt-thunderstorm' },
    rainshowersandthunder:       { day: 'wi-day-storm-showers',       night: 'wi-night-alt-storm-showers' },
    heavyrainshowersandthunder:  { day: 'wi-day-storm-showers',       night: 'wi-night-alt-storm-showers' },
    lightsleetandthunder:        { day: 'wi-day-sleet-storm',         night: 'wi-night-alt-sleet-storm' },
    sleetandthunder:             { day: 'wi-day-sleet-storm',         night: 'wi-night-alt-sleet-storm' },
    heavysleetandthunder:        { day: 'wi-day-sleet-storm',         night: 'wi-night-alt-sleet-storm' },
    lightsnowandthunder:         { day: 'wi-day-snow-thunderstorm',   night: 'wi-night-alt-snow-thunderstorm' },
    snowandthunder:              { day: 'wi-day-snow-thunderstorm',   night: 'wi-night-alt-snow-thunderstorm' },
    heavysnowandthunder:         { day: 'wi-day-snow-thunderstorm',   night: 'wi-night-alt-snow-thunderstorm' },
    sleetshowersandthunder:      { day: 'wi-day-sleet-storm',         night: 'wi-night-alt-sleet-storm' },
    heavysleetshowersandthunder: { day: 'wi-day-sleet-storm',         night: 'wi-night-alt-sleet-storm' },
    snowshowersandthunder:       { day: 'wi-day-snow-thunderstorm',   night: 'wi-night-alt-snow-thunderstorm' },
    heavysnowshowersandthunder:  { day: 'wi-day-snow-thunderstorm',   night: 'wi-night-alt-snow-thunderstorm' }
  };

  function iconDataUri(symbolCode) {
    var fallback = ICONS['wi-na'] || '';
    if (!symbolCode) return fallback;
    var isNight = symbolCode.indexOf('_night') !== -1 || symbolCode.indexOf('_polartwilight') !== -1;
    var base = symbolCode.replace(/_day$/, '').replace(/_night$/, '').replace(/_polartwilight$/, '');
    var entry = ICON_MAP[base];
    if (!entry) return fallback;
    var name = isNight ? entry.night : entry.day;
    return ICONS[name] || fallback;
  }

  /* ────────────────────────────────────
     D. Føles som (apparent temperature)
     ──────────────────────────────────── */
  function feelsLike(tempC, windMs, humidity) {
    /* Wind chill: temp < 10°C and wind > 1.33 m/s */
    if (tempC < 10 && windMs > 1.33) {
      var v = windMs * 3.6; /* km/h */
      return 13.12 + 0.6215 * tempC - 11.37 * Math.pow(v, 0.16) + 0.3965 * tempC * Math.pow(v, 0.16);
    }
    /* Heat index: temp > 26°C and humidity > 40% */
    if (tempC > 26 && humidity > 40) {
      var T = tempC;
      var R = humidity;
      var hi = -8.78469475556 + 1.61139411 * T + 2.33854883889 * R
        - 0.14611605 * T * R - 0.012308094 * T * T
        - 0.0164248277778 * R * R + 0.002211732 * T * T * R
        + 0.00072546 * T * R * R - 0.000003582 * T * T * R * R;
      return hi;
    }
    return tempC;
  }

  /* ────────────────────────────────────
     E. Filter today's data (06-22 Oslo)
     ──────────────────────────────────── */
  var hours = [], temps = [], precip = [], iconCodes = [];
  var allTemps = [];
  var currentEntry = null;

  timeseries.forEach(function (entry) {
    var h = osloHour(entry.time);
    var d = osloDay(entry.time);
    var inst = entry.data && entry.data.instant && entry.data.instant.details;
    var next1 = entry.data && entry.data.next_1_hours;

    if (d === todayDay && inst) {
      allTemps.push(inst.air_temperature);
    }

    /* Find the entry closest to "now" for current conditions */
    if (d === todayDay && !currentEntry) {
      var entryMs = new Date(entry.time).getTime();
      if (entryMs >= tsUtc - 3600000) {
        currentEntry = entry;
      }
    }

    /* Chart data: hours 6-22, today only */
    if (d === todayDay && h >= 6 && h <= 22 && inst && next1) {
      hours.push(h);
      temps.push(Math.round(inst.air_temperature * 10) / 10);
      var pa = (next1.details && next1.details.precipitation_amount) || 0;
      precip.push(pa);
      iconCodes.push(next1.summary ? next1.summary.symbol_code : null);
    }
  });

  /* Fallback: if no currentEntry found, use first today entry */
  if (!currentEntry) {
    for (var i = 0; i < timeseries.length; i++) {
      if (osloDay(timeseries[i].time) === todayDay) { currentEntry = timeseries[i]; break; }
    }
  }

  /* ────────────────────────────────────
     F. Render current conditions
     ──────────────────────────────────── */
  if (currentEntry) {
    var inst = currentEntry.data.instant.details;
    var next1 = currentEntry.data.next_1_hours;
    var symCode = (next1 && next1.summary) ? next1.summary.symbol_code : null;

    document.getElementById('current-icon').src = iconDataUri(symCode);

    var tempRound = Math.round(inst.air_temperature);
    document.getElementById('current-temp').textContent = tempRound + '\u00B0';

    var fl = feelsLike(inst.air_temperature, inst.wind_speed, inst.relative_humidity || 50);
    var flRound = Math.round(fl);
    if (flRound !== tempRound) {
      document.getElementById('current-feels').textContent = 'F\u00F8les som ' + flRound + '\u00B0';
    } else {
      document.getElementById('current-feels').textContent = '';
    }

    /* High / Low from all today's temperatures */
    var hi = Math.round(Math.max.apply(null, allTemps));
    var lo = Math.round(Math.min.apply(null, allTemps));
    document.getElementById('current-highlow').innerHTML =
      '<span>\u2191' + hi + '\u00B0</span><span>\u2193' + lo + '\u00B0</span>';

    /* Wind */
    document.getElementById('current-wind').innerHTML =
      '<img src="' + ICONS['wi-strong-wind'] + '" alt="vind" />' +
      '<span>' + Math.round(inst.wind_speed) + ' m/s</span>';
  }

  /* ────────────────────────────────────
     G. Highcharts chart
     ──────────────────────────────────── */
  Highcharts.setOptions({
    chart: { animation: false, backgroundColor: 'transparent', style: { fontFamily: 'sans-serif' } },
    title: { text: null },
    plotOptions: { series: { animation: false, enableMouseTracking: false } },
    tooltip: { enabled: false },
    credits: { enabled: false }
  });

  var cats = hours.map(function (h) {
    return (h < 10 ? '0' : '') + h;
  });

  var precipSeries = precip.map(function (v) { return v || 0; });

  /* precipMax: full max amount (gray behind), precip: actual amount (solid black in front).
     Both series overlap at the same width. The gray bar is taller, so only the
     gray extension above the black bar is visible — like Yr's chart. */
  var precipMax = precip.map(function (v) {
    return v > 0 ? Math.round(v * 1.3 * 10) / 10 : 0;
  });

  /* ────────────────────────────────────
     H. Clothing recommendation via OpenRouter
     ──────────────────────────────────── */
  var apiKey = '{{ openrouter_api_key }}';

  if (apiKey && currentEntry) {
    var inst = currentEntry.data.instant.details;
    var totalPrecip = 0;
    var maxHourlyPrecip = 0;
    var conditions = [];
    precip.forEach(function (v) { totalPrecip += v; });
    precip.forEach(function (v) { if (v > maxHourlyPrecip) maxHourlyPrecip = v; });
    iconCodes.forEach(function (code) {
      if (code) {
        var base = code.replace(/_day|_night|_polartwilight/, '');
        if (conditions.indexOf(base) === -1) conditions.push(base);
      }
    });

    var hi = allTemps.length ? Math.round(Math.max.apply(null, allTemps)) : Math.round(inst.air_temperature);
    var lo = allTemps.length ? Math.round(Math.min.apply(null, allTemps)) : Math.round(inst.air_temperature);
    var fl = feelsLike(inst.air_temperature, inst.wind_speed, inst.relative_humidity || 50);

    var willRainLater = false;
    for (var ri = 0; ri < precip.length; ri++) {
      if (precip[ri] > 0 && hours[ri] > osloHour(currentEntry.time)) { willRainLater = true; break; }
    }

    var weatherReport = {
      naa: {
        temperatur: Math.round(inst.air_temperature),
        foeles_som: Math.round(fl),
        vind_ms: Math.round(inst.wind_speed * 10) / 10,
        vaertype: iconCodes[0] || 'ukjent'
      },
      idag: {
        maks_temp: hi,
        min_temp: lo,
        total_nedboer_mm: Math.round(totalPrecip * 10) / 10,
        maks_nedboer_per_time_mm: Math.round(maxHourlyPrecip * 10) / 10,
        regn_kommer_senere: willRainLater,
        vaertyper: conditions
      }
    };

    var prompt = 'Du er en værassistent for barn. Gi et kort klestips (maks 15 ord) basert på dette været:\n\n'
      + JSON.stringify(weatherReport, null, 2)
      + '\n\nRegler:\n'
      + '- Svar KUN med klestipset, ingen annen tekst\n'
      + '- Bruk enkelt norsk som en 10-åring forstår\n'
      + '- Fokuser på yttertøy: jakke, regntøy, lue, votter, solbriller osv\n'
      + '- Nevn regntøy/paraply hvis det kommer regn\n'
      + '- Nevn lue/votter hvis det er kaldt (under 5°C)\n'
      + '- Vær positiv og hyggelig';

    fetch('https://openrouter.ai/api/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + apiKey,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        model: 'openai/gpt-4.1-nano',
        max_tokens: 60,
        temperature: 0.7,
        messages: [{ role: 'user', content: prompt }]
      })
    })
    .then(function (res) { return res.json(); })
    .then(function (data) {
      if (data.choices && data.choices[0] && data.choices[0].message) {
        var tip = data.choices[0].message.content.trim();
        document.getElementById('weather-tip').textContent = tip;
      }
    })
    .catch(function () {
      /* Keep default "Ha en fin dag!" on error */
    });
  }

  Highcharts.chart('weather-chart', {
    chart: {
      height: null,
      width: null,
      animation: false,
      spacing: [10, 10, 5, 10],
      backgroundColor: 'transparent'
    },
    title: { text: null },
    tooltip: { enabled: false },
    credits: { enabled: false },
    legend: { enabled: false },
    plotOptions: {
      series: {
        animation: false,
        enableMouseTracking: false,
        states: { hover: { enabled: false } }
      },
      column: {
        borderWidth: 0,
        grouping: false,
        pointPadding: 0.02
      }
    },
    xAxis: {
      categories: cats,
      type: 'category',
      lineWidth: 0,
      tickWidth: 0,
      tickLength: 0,
      gridLineWidth: 1,
      gridLineDashStyle: 'Dot',
      gridLineColor: '#000000',
      labels: {
        step: 2,
        style: { fontSize: '16px', color: '#000000' },
        padding: 5,
        y: 25
      }
    },
    yAxis: [
      {
        title: { text: null },
        labels: {
          format: '{value}\u00B0',
          style: { fontSize: '16px', color: '#000000' }
        },
        gridLineDashStyle: 'ShortDot',
        gridLineColor: '#000000',
        gridLineWidth: 1,
        tickAmount: 5
      },
      {
        title: { text: null },
        labels: {
          format: '{value} mm',
          style: { fontSize: '14px', color: '#000000' }
        },
        opposite: true,
        min: 0,
        softMax: 2,
        gridLineWidth: 0,
        tickAmount: 3
      }
    ],
    series: [
      {
        name: 'Temperatur',
        type: 'spline',
        data: temps,
        color: '#000000',
        lineWidth: 4,
        marker: { enabled: false },
        zIndex: 3,
        yAxis: 0
      },
      {
        name: 'Mulig nedb\u00F8r',
        type: 'column',
        data: precipMax,
        color: {
          pattern: {
            image: 'https://trmnl.com/images/grayscale/gray-5.png',
            width: 12,
            height: 12
          }
        },
        yAxis: 1,
        zIndex: 1
      },
      {
        name: 'Nedb\u00F8r',
        type: 'column',
        data: precipSeries,
        color: '#000000',
        yAxis: 1,
        zIndex: 2
      }
    ]
  }, function (chart) {
    /* ── Weather icons along the temperature line ── */
    var tempSeries = chart.series[0];
    var iconSize = 30;
    if (tempSeries && tempSeries.points) {
      tempSeries.points.forEach(function (point, idx) {
        if (idx % 2 !== 0) return;
        if (!iconCodes[idx]) return;
        var x = point.plotX + chart.plotLeft - iconSize / 2;
        var y = point.plotY + chart.plotTop - iconSize - 12;
        chart.renderer.image(iconDataUri(iconCodes[idx]), x, y, iconSize, iconSize)
          .attr({ zIndex: 5 })
          .add();
      });
    }
  });
});
</script>
